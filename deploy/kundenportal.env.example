# Konfiguration fuer das Kundenportal-Deployment mit reinem Podman.
#
# Kopiere diese Datei nach `kundenportal.env`, trage echte Werte ein und
# starte dann mit:  ./deploy/kundenportal.sh up
#
# Das Start-Skript liest standardmaessig deploy/kundenportal.env. Ein anderer
# Pfad laesst sich per `--env-file <pfad>` oder Umgebungsvariable
# KUNDENPORTAL_ENV uebergeben. Einzelne Werte koennen zusaetzlich per
# Umgebungsvariable ueberschrieben werden.

# ---------------------------------------------------------------------------
# Pflichtwerte (muessen gesetzt werden!)
# ---------------------------------------------------------------------------

# Oeffentlicher Hostname. Bei einem echten Domainnamen holt Caddy automatisch
# ein Let's-Encrypt-Zertifikat und erzwingt HTTPS.
# Fuer einen ersten Test ohne TLS:  DOMAIN=:80
DOMAIN=heihaf.kiste.org

# Datenbank-Zugangsdaten
POSTGRES_DB=kundenportal
POSTGRES_USER=kundenportal
POSTGRES_PASSWORD=BITTE-STARKES-DB-PASSWORT-SETZEN

# Auth-Secrets
JWT_SECRET=BITTE-ZUFAELLIGEN-32-ZEICHEN-STRING-SETZEN
INITIAL_ADMIN_PASSWORD=BITTE-ADMIN-START-PASSWORT-SETZEN

# ---------------------------------------------------------------------------
# Optionale Werte (sinnvolle Defaults)
# ---------------------------------------------------------------------------

JWT_EXPIRE_HOURS=8
LOG_LEVEL=INFO
# 2FA-Pflicht fuer interne Rollen (admin/user). false = optional (Default).
REQUIRE_2FA=false

# Adapter-Provider
# SIGNATURE_PROVIDER: inhouse (einziger Provider) – Unterschrift im Portal
#   zeichnen -> PDF wird erzeugt und kryptografisch versiegelt (= FES)
SIGNATURE_PROVIDER=inhouse
AVV_PROVIDER=stub
TARGET_SYSTEM_PROVIDER=stub
NOTIFICATION_PROVIDER=stub

# Signatur inhouse: optionales eigenes Siegel-Zertifikat (PKCS#12). Leer =
# automatisch selbstsigniert (im Volume <PROJECT>_documents abgelegt).
SIGNING_CERT_PATH=
SIGNING_CERT_PASSWORD=

# Beim ersten Hochfahren optional Demo-Daten anlegen (idempotent):
SEED_DEMO_DATA=false

# Host-Ports, auf die Caddy veroeffentlicht wird. Fuer rootless-Podman ggf.
# hoehere Ports (z.B. 8080/8443) verwenden – siehe deploy/README.md.
HTTP_PORT=80
HTTPS_PORT=443

# ---------------------------------------------------------------------------
# Namen/Tags (nur aendern, wenn mehrere Instanzen auf einem Host laufen sollen)
# ---------------------------------------------------------------------------
PROJECT=kundenportal
IMAGE_TAG=latest
POSTGRES_IMAGE=docker.io/postgres:16
