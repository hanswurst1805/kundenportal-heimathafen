# ---------------------------------------------------------------------------
# Entwicklung (podman-compose.yml): nur DATABASE_URL/JWT/INITIAL_ADMIN_PASSWORD
# noetig, die DB laeuft mit Default-Zugangsdaten.
# ---------------------------------------------------------------------------

# Datenbank (Entwicklung, lokal gegen Podman-DB auf Port 5433)
DATABASE_URL=postgresql+asyncpg://kundenportal:kundenportal@localhost:5433/kundenportal

# Auth
JWT_SECRET=change-me-to-a-random-32-byte-string
JWT_EXPIRE_HOURS=8
INITIAL_ADMIN_PASSWORD=change-me

# Adapter-Provider (stub | real)
SIGNATURE_PROVIDER=stub
AVV_PROVIDER=stub
TARGET_SYSTEM_PROVIDER=stub
NOTIFICATION_PROVIDER=stub

# Deployment
DOMAIN=heihaf.kiste.org
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Produktion (podman-compose.prod.yml): die DB-Zugangsdaten werden aus den
# folgenden Variablen zusammengesetzt. DATABASE_URL oben wird im Prod-Stack
# ignoriert (api setzt sie selbst aus POSTGRES_*).
# Fuer lokales Testen ohne echtes TLS: DOMAIN=:80 setzen.
# ---------------------------------------------------------------------------
POSTGRES_DB=kundenportal
POSTGRES_USER=kundenportal
POSTGRES_PASSWORD=change-me-strong-db-password

# Beim ersten Hochfahren optional Demo-Daten anlegen (idempotent):
SEED_DEMO_DATA=false
